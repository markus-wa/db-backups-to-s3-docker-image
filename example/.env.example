
VERBOSE="4"
LOG_DIR="/var/log/backups"
DEL_LOCAL="1"

# Backup schedule in cron format (default: 0 0 * * * = midnight daily)
# Examples:
#   0 0 * * * = Every day at midnight
#   */10 * * * * = Every 10 minutes
#   0 2 * * 0 = Every Sunday at 2 AM
#   0 */6 * * * = Every 6 hours
BACKUP_SCHEDULE="0 0 * * *"

S3_ENDPOINT="s3.endpoint.com"
S3_KEY_ID="changeme123"
S3_APP_KEY="changeme123"
S3_BUCKET="test-backups"
S3_BUCKET_DIR="database"

DB_TYPE="mysql"
DB_HOST="db"
DB_NAME="test-db"
DB_USER="root"
DB_PASS="changeme123"
DB_PORT="3306"

# Optional: Exclude specific tables from backup (comma-separated)
# Examples:
#   MySQL: EXCLUDE_TABLES="cache,sessions,logs"
#   PostgreSQL: EXCLUDE_TABLES="public.cache,audit.logs"
#EXCLUDE_TABLES=""

DUP_FORCE_INC=0
DUP_FORCE_FULL=0
# Force a full backup when the last full is older than this interval (duplicity format: 7D, 2W, 1M).
# Ignored when DUP_FORCE_FULL or DUP_FORCE_INC are set.
#DUP_FULL_IF_OLDER_THAN="7D"
# Keep only the last N full backups (and their incrementals). Older chains are deleted automatically.
#DUP_KEEP_N_FULL="3"

# Encryption: Choose ONE method
# Option 1: GPG public key encryption (recommended - no passphrase needed on backup server)
#   Requires mounting /root/.gnupg volume with your public key
GPG_KEY_ID=""
# Option 2: Symmetric encryption with passphrase (less secure)
#   Used as fallback if GPG_KEY_ID is not set
DUP_PASS="changeme123"

# Optional: Healthchecks.io monitoring
# Uncomment and set your ping URL to enable backup monitoring
#HC_PING_URL="https://hc-ping.com/your-uuid-here"